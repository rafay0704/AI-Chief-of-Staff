# ── Copy to .env and adjust. .env is gitignored. ──────────────────────────────

# HTTP server
APP_ENV=development          # development | production
HTTP_PORT=8080
LOG_LEVEL=info               # debug | info | warn | error

# PostgreSQL (matches docker-compose.yml)
DATABASE_URL=postgres://acos:acos_dev_pw@localhost:5433/acos?sslmode=disable

# Redis (matches docker-compose.yml)
REDIS_ADDR=localhost:6379
REDIS_PASSWORD=
REDIS_DB=0

# Auth
JWT_SECRET=change-me-to-a-long-random-string-in-production
JWT_TTL_HOURS=24

# Anthropic Claude (needed from Batch 3 onward)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# Worker pool
WORKER_CONCURRENCY=4
